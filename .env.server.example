## Backend (Express) config
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
# Публичный URL сайта (кнопки в Telegram-боте). В Docker часто: http://localhost:3001
SITE_URL=http://localhost:5173
JWT_SECRET=change_me_to_a_long_random_string
# Mode A (default): SQLite. Works locally without external DB.
DB_PATH=server/data.sqlite
# Mode B: PostgreSQL (Supabase/Render Postgres). If DATABASE_URL is set, app uses PostgreSQL instead of SQLite.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
TELEGRAM_BOT_TOKEN=put_your_bot_token_here
ADMIN_PASSWORD=change_me
# Telegram user IDs (comma-separated) who can use bot admin commands
TELEGRAM_ADMIN_IDS=123456789

